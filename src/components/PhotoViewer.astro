---
export interface Photo {
  url: string;
  alt: string;
  exif?: string;
}

export interface Props {
  photos?: Photo[];
}
---

<div
  id="photo-viewer"
  transition:persist="photo-viewer"
  class="fixed inset-0 z-[999] flex items-center justify-center bg-black/95 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300 ease-out"
  data-viewer-active="false"
>
  <button
    id="viewer-close"
    class="absolute top-6 right-6 z-10 p-2 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors duration-200 group"
    aria-label="Close photo viewer"
    type="button"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-6 group-hover:rotate-90 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <button
    id="viewer-prev"
    class="absolute left-6 top-1/2 -translate-y-1/2 z-10 p-3 rounded-full bg-white/10 hover:bg-white/20 text-white transition-all duration-200 disabled:opacity-0"
    aria-label="Previous photo"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <button
    id="viewer-next"
    class="absolute right-6 top-1/2 -translate-y-1/2 z-10 p-3 rounded-full bg-white/10 hover:bg-white/20 text-white transition-all duration-200 disabled:opacity-0"
    aria-label="Next photo"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <div class="relative w-full h-full flex items-center justify-center p-4 sm:p-12 md:p-20">
    <div id="viewer-loading" class="absolute inset-0 flex items-center justify-center text-white/50">
      <svg class="animate-spin h-8 w-8" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </div>
    <img
      id="viewer-image"
      class="max-w-full max-h-full object-contain shadow-2xl opacity-0 transition-opacity duration-300 pointer-events-none select-none"
      src=""
      alt=""
    />
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 w-full px-6">
    <div class="flex items-center gap-4 px-5 py-2.5 bg-black/60 backdrop-blur-xl text-white text-sm rounded-full shadow-2xl border border-white/10">
      <span id="viewer-counter" class="font-mono tabular-nums opacity-80"></span>
      <div class="w-px h-4 bg-white/20"></div>
      <span id="viewer-title" class="max-w-[200px] sm:max-w-xs truncate font-medium"></span>
    </div>

    <div id="viewer-exif" class="hidden px-3 py-1 bg-white/5 backdrop-blur-sm text-white/60 text-[10px] uppercase tracking-[0.2em] rounded border border-white/5">
    </div>
  </div>
</div>

<script>
  interface Photo {
    url: string;
    alt: string;
    exif?: string;
  }

  interface WindowWithPhotoViewer extends Window {
    openPhotoViewer?: (photos: Photo[], index?: number) => void;
    __photoViewerSystem?: PhotoViewerSystem;
  }

  class PhotoViewerSystem {
    private viewer: HTMLElement;
    private image: HTMLImageElement;
    private loading: HTMLElement;
    private counter: HTMLElement;
    private title: HTMLElement;
    private exif: HTMLElement;
    private prevBtn: HTMLButtonElement;
    private nextBtn: HTMLButtonElement;
    private photos: Photo[] = [];
    private currentIndex = 0;

    constructor() {
      this.viewer = document.getElementById("photo-viewer")!;
      this.image = document.getElementById("viewer-image") as HTMLImageElement;
      this.loading = document.getElementById("viewer-loading")!;
      this.counter = document.getElementById("viewer-counter")!;
      this.title = document.getElementById("viewer-title")!;
      this.exif = document.getElementById("viewer-exif")!;
      this.prevBtn = document.getElementById("viewer-prev") as HTMLButtonElement;
      this.nextBtn = document.getElementById("viewer-next") as HTMLButtonElement;

      this.initEvents();
    }

    private initEvents() {
      document.getElementById("viewer-close")?.addEventListener("click", () => this.close());
      this.prevBtn.addEventListener("click", () => this.navigate(-1));
      this.nextBtn.addEventListener("click", () => this.navigate(1));
      this.viewer.addEventListener("click", (e) => {
        if (e.target === this.viewer || e.target === this.viewer.firstElementChild) this.close();
      });

      window.addEventListener("keydown", (e) => {
        if (this.viewer.getAttribute("data-viewer-active") !== "true") return;
        if (e.key === "Escape") this.close();
        if (e.key === "ArrowLeft") this.navigate(-1);
        if (e.key === "ArrowRight") this.navigate(1);
      });
    }

    public open(photos: Photo[], index = 0) {
      this.photos = photos;
      this.currentIndex = index;
      this.viewer.setAttribute("data-viewer-active", "true");
      this.viewer.classList.remove("opacity-0", "pointer-events-none");
      document.body.style.overflow = "hidden";
      this.updatePhoto();
    }

    public close() {
      this.viewer.setAttribute("data-viewer-active", "false");
      this.viewer.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
      setTimeout(() => this.clearState(), 300);
    }

    private navigate(direction: number) {
      const newIndex = this.currentIndex + direction;
      if (newIndex >= 0 && newIndex < this.photos.length) {
        this.currentIndex = newIndex;
        this.updatePhoto();
      }
    }

    private updatePhoto() {
      const photo = this.photos[this.currentIndex];
      if (!photo) return;

      this.image.style.opacity = "0";
      this.loading.style.display = "flex";
      this.image.src = photo.url;
      this.image.alt = photo.alt;

      this.image.onload = () => {
        this.image.style.opacity = "1";
        this.loading.style.display = "none";
      };

      this.updateInfo();
    }

    private updateInfo() {
      const photo = this.photos[this.currentIndex];
      this.counter.textContent = `${this.currentIndex + 1} / ${this.photos.length}`;
      this.title.textContent = photo?.alt || "";

      if (photo?.exif) {
        this.exif.textContent = photo.exif;
        this.exif.classList.remove("hidden");
      } else {
        this.exif.classList.add("hidden");
      }

      this.prevBtn.disabled = this.currentIndex === 0;
      this.nextBtn.disabled = this.currentIndex === this.photos.length - 1;
    }

    private clearState() {
      this.image.src = "";
      this.exif.textContent = "";
      this.exif.classList.add("hidden");
    }

    public isReady() { return true; }
  }

  const win = window as WindowWithPhotoViewer;
  if (!win.__photoViewerSystem) {
    win.__photoViewerSystem = new PhotoViewerSystem();
    win.openPhotoViewer = (photos: Photo[], index = 0) => win.__photoViewerSystem?.open(photos, index);
  }
</script>
