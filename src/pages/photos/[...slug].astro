---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import BackToPrev from "@components/BackToPrev.astro";
import Link from "@components/Link.astro";
import PhotoViewer from "@components/PhotoViewer.astro";
import { getPhotoVariant } from "@lib/photos";

export async function getStaticPaths() {
  const collections = (await getCollection("photos"))
    .filter((collection) => !collection.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return collections.map((collection) => ({
    params: { slug: collection.id.replace(/\/index$/, "") },
    props: collection,
  }));
}

type Props = CollectionEntry<"photos">;

const collection = Astro.props;
const { Content } = await render(collection);
---

<PageLayout
  title={collection.data.title}
  description={collection.data.description}
  type="article"
  date={collection.data.date}
>
  <Container>
    <div>
      <BackToPrev href="/photos">
        Back to photos
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={collection.data.date} />
        </div>
        {collection.data.photos && (
          <>
            &bull;
            <div class="font-base text-sm">
              {collection.data.photos.length} photos
            </div>
          </>
        )}
      </div>
      <div class="text-2xl font-semibold text-black dark:text-white">
        {collection.data.title}
      </div>
      {collection.data.collectionURL && (
        <nav class="flex gap-1">
          <Link href={collection.data.collectionURL} external>
            unsplash
          </Link>
        </nav>
      )}
    </div>

    <article class="mb-8">
      <Content />
    </article>

    {collection.data.photos && collection.data.photos.length > 0 && (
      <div class="space-y-6" data-photo-collection>
        {collection.data.photos.map((photo, index) => {
          const thumbnailSrc = getPhotoVariant(photo.url, {
            width: 1280,
            quality: 72,
          });
          const fullSrc = getPhotoVariant(photo.url, {
            width: 2200,
            quality: 80,
          });

          return (
            <div class:list={["w-full", index > 1 && "defer-render"]}>
              <button
                type="button"
                class="photo-item w-full cursor-pointer focus:outline-none focus:ring-2 focus:ring-black/20 dark:focus:ring-white/30 rounded-lg group"
                data-photo-item
                data-photo-index={index}
                data-photo-url={fullSrc}
                data-photo-alt={photo.alt}
                aria-label={`View photo: ${photo.alt}`}
              >
                <Image
                  src={thumbnailSrc}
                  inferSize
                  alt={photo.alt}
                  widths={[320, 480, 640, 750, 960, 1280]}
                  sizes="(min-width: 680px) 640px, calc(100vw - 2.5rem)"
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={index === 0 ? "high" : "auto"}
                  class="w-full h-auto rounded-lg shadow-md group-hover:shadow-xl transition-shadow duration-300"
                />
              </button>
            </div>
          );
        })}
      </div>
    )}

    <PhotoViewer />

    <script>
      import { bindPhotoCollection } from "@lib/client/photo-gallery";

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => bindPhotoCollection(), {
          once: true,
        });
      } else {
        bindPhotoCollection();
      }
    </script>
  </Container>
</PageLayout>
